{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/session-start.sh\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/dashboard-autostart.sh\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/log-tool-event.sh\" session_start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/user-prompt-submit.sh\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/log-tool-event.sh\" user_prompt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/pre-tool-edit.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/pre-tool-bash.sh\""
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/log-tool-event.sh\" agent_start"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/log-tool-event.sh\" skill_invoke"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "STDIN=$(cat); FILE_PATH=$(echo \"$STDIN\" | jq -r '.tool_input.file_path // \"\"' 2>/dev/null); if echo \"$FILE_PATH\" | grep -qE '\\.claude/agents/.*\\.md$'; then echo \"$(date -u -Iseconds) $FILE_PATH (edit detected; consider running /audit-subagents)\" | LOGFILE=subagent-edits.log bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/log-event.sh\"; fi"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/log-tool-event.sh\" agent_complete"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/log-tool-event.sh\" bash_complete"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/log-tool-event.sh\" grill_qa"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/log-tool-event.sh\" session_stop"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/stop-reviewer-gate.sh\""
          }
        ]
      }
    ]
  }
}
