{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/session-start.sh\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/dashboard-autostart.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/user-prompt-submit.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/pre-tool-edit.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/pre-tool-bash.sh\""
          }
        ]
      },
      {
        "matcher": "Agent|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/log-tool-event.sh\" auto"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent|Bash|AskUserQuestion|Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/log-tool-event.sh\" auto"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)\")}/.claude/hooks/stop-reviewer-gate.sh\""
          }
        ]
      }
    ]
  }
}
