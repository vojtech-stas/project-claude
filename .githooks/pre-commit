#!/bin/sh
# .githooks/pre-commit
#
# Purpose:
#   Local-side workflow enforcement for project-claude. Layer 1 of the
#   three-layer bypass-prevention stack defined in ADR-0004 D3.
#
# When it runs:
#   Before every `git commit` in any clone that has run `.githooks/install.sh`
#   (which sets `git config core.hooksPath .githooks`).
#
# What it blocks:
#   1. Commits while HEAD is the `main` branch — direct commits to main are
#      banned per CLAUDE.md cross-cutting rule #4.
#   2. Commits on a branch whose name does NOT match the regex
#        ^(feat|fix|chore|refactor|docs|test|perf|style|build|ci|hotfix)/[0-9]+-[a-z0-9-]+$
#      i.e. <conventional-type>/<issue-number>-<kebab-slug>.
#
# Fail-open policy (per PRD #15 §6 OQ#2):
#   On detached HEAD, initial-commit-with-no-branch, or any branch-name
#   detection failure, this hook prints a warning to stderr and exits 0.
#   Rationale: false negatives on legitimate edge cases (bisect, worktree
#   setup, rebase in progress) are cheaper than blocking real workflows.
#   Server-side enforcement (branch protection) and PR-time review
#   (reviewer subagent) catch what slips through here.
#
# Bypass note:
#   `git commit --no-verify` skips this hook. That is accepted per ADR-0004
#   Consequences — the higher layers exist precisely for that case.
#
# See:
#   - decisions/0004-bypass-prevention.md (D3 layer 1)
#   - .githooks/install.sh

set -u

# Detect current branch. `git symbolic-ref --short HEAD` returns the branch
# name on success and prints to stderr + non-zero exit on detached HEAD.
branch=$(git symbolic-ref --short HEAD 2>/dev/null) || branch=""

if [ -z "$branch" ]; then
    echo "pre-commit: warning: could not determine branch name (detached HEAD, initial commit, or rebase in progress); allowing commit per fail-open policy. See ADR-0004 D3." >&2
    exit 0
fi

if [ "$branch" = "main" ]; then
    echo "pre-commit: ERROR: direct commits to 'main' are not allowed." >&2
    echo "pre-commit: Use a feature branch matching <type>/<issue#>-<slug> instead, e.g.:" >&2
    echo "pre-commit:   git checkout -b feat/42-add-something" >&2
    echo "pre-commit: See CLAUDE.md cross-cutting rule #4 and ADR-0004 D3." >&2
    exit 1
fi

# POSIX-compatible regex match via `expr`. The pattern below mirrors the
# canonical regex in ADR-0004 D3 and PRD #15 §2.
pattern='^\(feat\|fix\|chore\|refactor\|docs\|test\|perf\|style\|build\|ci\|hotfix\)/[0-9][0-9]*-[a-z0-9-][a-z0-9-]*$'
if ! expr "$branch" : "$pattern" >/dev/null 2>&1; then
    echo "pre-commit: ERROR: branch name '$branch' does not match the required pattern." >&2
    echo "pre-commit: Expected: <type>/<issue#>-<kebab-slug>" >&2
    echo "pre-commit: Regex:    ^(feat|fix|chore|refactor|docs|test|perf|style|build|ci|hotfix)/[0-9]+-[a-z0-9-]+\$" >&2
    echo "pre-commit: Examples: feat/16-pre-commit-hook   docs/8-claude-md-rollup   hotfix/42-typo-fix" >&2
    echo "pre-commit: See CLAUDE.md 'Operational git workflow' and ADR-0004 D3." >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# README currency check — ADR-0034 D6 (pre-commit doc-generation gate)
# ---------------------------------------------------------------------------
# Regenerate README.md from README.template.md + filesystem; if the
# committed README differs from the freshly-generated one, block the commit.
#
# Fail-open cases (warn + exit 0, consistent with branch-name check above):
#   - Python not found
#   - Generator script not found
#   - Generator fails (e.g., template missing)
#
# Bypass note: `git commit --no-verify` skips this check. That is accepted per
# ADR-0034 D9 / ADR-0004 Consequences — the R-DOCS-CURRENT reviewer rule
# (the unbypassable merge gate) catches what --no-verify skips.
#
# Cross-platform (ADR-0030): try python3 first, then python.

PYTHON=$(command -v python3 2>/dev/null || command -v python 2>/dev/null) || PYTHON=""

if [ -z "$PYTHON" ]; then
    echo "pre-commit: warning: python not found; skipping README currency check (fail-open). See ADR-0034 D6." >&2
    exit 0
fi

# Locate the repo root (the directory containing .githooks/).
# Use `git rev-parse --show-toplevel`; handle paths with spaces via quoting.
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || REPO_ROOT=""

if [ -z "$REPO_ROOT" ]; then
    echo "pre-commit: warning: could not determine repo root; skipping README currency check (fail-open). See ADR-0034 D6." >&2
    exit 0
fi

GENERATOR="$REPO_ROOT/dashboard/server.py"

if [ ! -f "$GENERATOR" ]; then
    echo "pre-commit: warning: generator not found at '$GENERATOR'; skipping README currency check (fail-open). See ADR-0034 D6." >&2
    exit 0
fi

# Run the generator. Capture stderr; on non-zero exit, fail-open with warning.
if ! "$PYTHON" "$GENERATOR" --generate-readme >/dev/null 2>&1; then
    echo "pre-commit: warning: README generator exited non-zero; skipping README currency check (fail-open). See ADR-0034 D6." >&2
    exit 0
fi

# If README.md changed relative to HEAD, the committed version is out of sync.
# Use `git diff --exit-code` on the worktree state (not staged vs HEAD, but
# worktree vs HEAD — generator wrote to the worktree file).
if ! git -C "$REPO_ROOT" diff --exit-code README.md >/dev/null 2>&1; then
    echo "pre-commit: ERROR: README out of sync — run \`python dashboard/server.py --generate-readme\` and re-stage README.md before committing." >&2
    echo "pre-commit: (ADR-0034 D6 — defense-in-depth pre-commit doc-generation gate)" >&2
    # Restore README.md so the working tree is clean after blocking.
    git -C "$REPO_ROOT" checkout README.md >/dev/null 2>&1 || true
    exit 1
fi

# ---------------------------------------------------------------------------
# Secrets gate — advisory mirror of tools/ci-checks.sh CHECK 13 (ADR-0068 D2)
#
# NEVER-LIST RULE: a secret that reaches a commit is ROTATED immediately —
# allowlisting a real secret is the named anti-pattern.
# This hook scans STAGED files only (not the full tracked tree).
# ci-checks.sh CHECK 13 is the gate of record; this hook is advisory speed.
# Fail-open: if python3 or git is unavailable, warn and allow commit.
# ---------------------------------------------------------------------------

_SECRETS_PYTHON=$(command -v python3 2>/dev/null || command -v python 2>/dev/null) || _SECRETS_PYTHON=""
if [ -z "$_SECRETS_PYTHON" ]; then
    echo "pre-commit: warning: python not found; skipping secrets gate (fail-open). See ADR-0068 D2." >&2
    exit 0
fi

"$_SECRETS_PYTHON" - "$REPO_ROOT" <<'SECRETS_EOF'
import re, sys, os, subprocess

REPO_ROOT = sys.argv[1] if len(sys.argv) > 1 else os.getcwd()

_SECRET_PATTERNS = [
    re.compile(
        r'(?i)(?:api[_-]?key|api[_-]?secret|auth[_-]?token|access[_-]?token'
        r'|secret[_-]?key|private[_-]?key|client[_-]?secret|oauth[_-]?token'
        r'|bearer[_-]?token|password)\s*[=:]\s*["\']?([A-Za-z0-9+/=_\-]{20,})["\']?'
    ),
    re.compile(r'\b(ghp_[A-Za-z0-9]{36,}|gho_[A-Za-z0-9]{36,}'
               r'|ghs_[A-Za-z0-9]{36,}|ghr_[A-Za-z0-9]{36,}'
               r'|github_pat_[A-Za-z0-9_]{36,})\b'),
    re.compile(r'\b(AKIA[A-Z0-9]{16})\b'),
    re.compile(
        r'(?i)(?:key|secret|token|password)\s*[=:]\s*["\']?([0-9a-f]{40,})["\']?'
    ),
]
_ENTROPY_RE = re.compile(r'[=:]\s*["\']?([A-Za-z0-9+/]{32,}={0,2})["\']?\s*$')
_ENTROPY_THRESHOLD = 4.2
_SKIP_PATH_RE = re.compile(
    r'^(decisions/|docs/|\.claude/logs/|\.claude/worktrees/|qa-proof/)',
    re.IGNORECASE
)

def shannon_entropy(s):
    if not s: return 0.0
    from collections import Counter; import math
    freq = Counter(s); n = len(s)
    return -sum((c/n)*math.log2(c/n) for c in freq.values())

_allowlist_patterns = []
allowlist_path = os.path.join(REPO_ROOT, 'tools', 'secrets-allowlist.txt')
if os.path.isfile(allowlist_path):
    with open(allowlist_path, 'r', encoding='utf-8', errors='replace') as _f:
        for _line in _f:
            _line = _line.strip()
            if _line and not _line.startswith('#'):
                try: _allowlist_patterns.append(re.compile(_line))
                except re.error: pass

def is_allowlisted(line_text):
    return any(p.search(line_text) for p in _allowlist_patterns)

try:
    result = subprocess.run(
        ['git', 'diff', '--cached', '--name-only', '--diff-filter=ACM'],
        capture_output=True, text=True, encoding='utf-8', cwd=REPO_ROOT)
    staged = [f.strip() for f in result.stdout.splitlines() if f.strip()]
except Exception as e:
    print(f'pre-commit: warning: could not list staged files: {e}', file=sys.stderr)
    sys.exit(0)

_BINARY_EXTS = {'.png','.jpg','.jpeg','.gif','.ico','.pdf','.zip','.tar',
                '.gz','.whl','.pyc','.so','.dll'}
violations = []
for filepath in staged:
    if _SKIP_PATH_RE.match(filepath): continue
    _, ext = os.path.splitext(filepath.lower())
    if ext in _BINARY_EXTS: continue
    full_path = os.path.join(REPO_ROOT, filepath)
    if not os.path.isfile(full_path): continue
    try:
        with open(full_path, 'r', encoding='utf-8', errors='replace') as f:
            for lineno, line in enumerate(f, 1):
                ls = line.rstrip('\n')
                if is_allowlisted(ls): continue
                for pat in _SECRET_PATTERNS:
                    if pat.search(ls):
                        violations.append((filepath, lineno, ls[:80], 'secret-pattern'))
                        break
                else:
                    em = _ENTROPY_RE.search(ls)
                    if em:
                        c = em.group(1); ent = shannon_entropy(c)
                        if ent >= _ENTROPY_THRESHOLD and len(c) >= 32:
                            violations.append((filepath, lineno, ls[:80],
                                               f'entropy={ent:.1f}'))
    except (OSError, UnicodeDecodeError):
        pass

if violations:
    print('pre-commit: ERROR: secrets gate detected secret-shaped strings:', file=sys.stderr)
    for fp, ln, text, reason in violations[:5]:
        print(f'  {fp}:{ln} [{reason}] {text}', file=sys.stderr)
    print('pre-commit: If false positive, add to tools/secrets-allowlist.txt with reason.', file=sys.stderr)
    print('pre-commit: NEVER allowlist a real secret — rotate it immediately.', file=sys.stderr)
    print('pre-commit: See ADR-0068 D2.', file=sys.stderr)
    sys.exit(1)
sys.exit(0)
SECRETS_EOF
_SECRETS_RC=$?
if [ "$_SECRETS_RC" -ne 0 ]; then
    exit 1
fi

exit 0
